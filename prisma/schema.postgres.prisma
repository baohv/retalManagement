generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("staff") // admin, staff
  phone     String   @default("")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Room {
  id           Int      @id @default(autoincrement())
  name         String
  floor        Int      @default(1)
  area         Float
  price        Float
  deposit      Float    @default(0)
  status       String   @default("available")
  description  String   @default("")
  amenities    String   @default("[]")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  contracts       Contract[]
  invoices        Invoice[]
  meterReadings   MeterReading[]
  maintenanceReqs MaintenanceRequest[]

  @@map("rooms")
}

model Tenant {
  id               Int      @id @default(autoincrement())
  fullName         String   @map("full_name")
  cccd             String   @unique
  phone            String
  email            String   @default("")
  permanentAddress String   @default("") @map("permanent_address")
  avatar           String   @default("")
  notes            String   @default("")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  contractTenants ContractTenant[]

  @@map("tenants")
}

model Contract {
  id             Int      @id @default(autoincrement())
  roomId         Int      @map("room_id")
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  rentPrice      Float    @map("rent_price")
  depositAmount  Float    @default(0) @map("deposit_amount")
  deposit_status  String   @default("pending")
  status         String   @default("active")
  terms          String   @default("")
  notes          String   @default("")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  room            Room              @relation(fields: [roomId], references: [id])
  contractTenants ContractTenant[]
  invoices        Invoice[]

  @@map("contracts")
}

model ContractTenant {
  id         Int      @id @default(autoincrement())
  contractId Int      @map("contract_id")
  tenantId   Int      @map("tenant_id")
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([contractId, tenantId])
  @@map("contract_tenants")
}

model Invoice {
  id            Int      @id @default(autoincrement())
  contractId    Int      @map("contract_id")
  roomId        Int      @map("room_id")
  invoiceNumber String   @unique @map("invoice_number")
  periodYear    Int      @map("period_year")
  periodMonth   Int      @map("period_month")
  issueDate     DateTime @map("issue_date")
  dueDate       DateTime @map("due_date")
  totalAmount   Float    @map("total_amount")
  status        String   @default("unpaid")
  notes         String   @default("")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  contract Contract      @relation(fields: [contractId], references: [id])
  room     Room          @relation(fields: [roomId], references: [id])
  items    InvoiceItem[]
  payments Payment[]

  @@map("invoices")
}

model InvoiceItem {
  id        Int      @id @default(autoincrement())
  invoiceId Int      @map("invoice_id")
  type      String
  label     String
  quantity  Float    @default(1)
  unitPrice Float    @map("unit_price")
  amount    Float    @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Payment {
  id            Int      @id @default(autoincrement())
  invoiceId     Int      @map("invoice_id")
  amount        Float
  paymentDate   DateTime @map("payment_date")
  paymentMethod String   @map("payment_method")
  reference     String   @default("")
  notes         String   @default("")
  createdAt     DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

model MeterReading {
  id              Int      @id @default(autoincrement())
  roomId          Int      @map("room_id")
  type            String
  readingDate     DateTime @map("reading_date")
  previousReading Float    @map("previous_reading")
  currentReading  Float    @map("current_reading")
  consumption     Float    @default(0)
  unitPrice       Float    @map("unit_price")
  createdAt       DateTime @default(now()) @map("created_at")

  room Room @relation(fields: [roomId], references: [id])

  @@map("meter_readings")
}

model MaintenanceRequest {
  id            Int       @id @default(autoincrement())
  roomId        Int       @map("room_id")
  title         String
  description   String    @default("")
  status        String    @default("pending")
  priority      String    @default("medium")
  estimatedCost Float     @default(0) @map("estimated_cost")
  actualCost    Float     @default(0) @map("actual_cost")
  completedAt   DateTime? @map("completed_at")
  notes         String    @default("")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  room Room @relation(fields: [roomId], references: [id])

  @@map("maintenance_requests")
}
